   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\"\"\n",
    "🎨 THREE PROFESSIONAL COLOR SCHEMES:\n",
    "\n",
    "1. 'ACADEMIC' (Default)\n",
    "   Colors: Deep Blue, Purple, Orange, Green, Red\n",
    "   Best for: Professional reports, academic papers, formal presentations\n",
    "   Tone: Serious, professional, traditional\n",
    "\n",
    "2. 'PASTEL'\n",
    "   Colors: Light Blue, Light Pink, Mauve, Cyan, Light Red\n",
    "   Best for: Educational materials, student presentations, friendly tone\n",
    "   Tone: Approachable, friendly, soft\n",
    "\n",
    "3. 'VIBRANT'\n",
    "   Colors: Red, Teal, Yellow, Mint, Dark Red\n",
    "   Best for: Posters, eye-catching presentations, modern design\n",
    "   Tone: Bold, energetic, contemporary\n",
    "\"\"\")\n",
    "\n",
    "# Try different color schemes\n",
    "bd_academic = bl.BizDesc(df_school, color_scheme='academic')\n",
    "bd_pastel = bl.BizDesc(df_school, color_scheme='pastel')\n",
    "bd_vibrant = bl.BizDesc(df_school, color_scheme='vibrant')\n",
    "\n",
    "print(\"✅ Three color schemes ready!\")\n",
    "print(\"   Try: bd_pastel.visualize('spending', plot_type='histogram')\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare the same visualization with different color schemes\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "\n",
    "schemes = [('academic', bd_academic), ('pastel', bd_pastel), ('vibrant', bd_vibrant)]\n",
    "\n",
    "for idx, (scheme_name, bd_scheme) in enumerate(schemes):\n",
    "    # Get data\n",
    "    data = df_school.to_pandas()['spending']\n",
    "    colors = bd_scheme.colors\n",
    "    \n",
    "    # Create histogram\n",
    "    axes[idx].hist(data, bins=25, alpha=0.7, color=colors['primary'], edgecolor='black', linewidth=0.5)\n",
    "    axes[idx].axvline(data.mean(), color=colors['accent'], linestyle='--', linewidth=2.5, label='Mean')\n",
    "    axes[idx].axvline(data.median(), color=colors['success'], linestyle='-', linewidth=2.5, label='Median')\n",
    "    \n",
    "    axes[idx].set_title(f\"{scheme_name.capitalize()} Scheme\", fontsize=12, fontweight='bold')\n",
    "    axes[idx].set_xlabel(\"Spending ($)\", fontweight='bold')\n",
    "    axes[idx].set_ylabel(\"Frequency\", fontweight='bold')\n",
    "    axes[idx].legend()\n",
    "    axes[idx].grid(alpha=0.3)\n",
    "\n",
    "plt.suptitle(\"Same Data, Three Color Schemes\", fontsize=14, fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
